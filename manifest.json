{
    "manifest_version": 3,
    "name": "Fading Days",
    "version": "1.0.0",
    "description": "Uświadom sobie upływ czasu. Odliczaj dni, weekendy, święta i wakacje do kluczowych momentów w życiu.",
    "permissions": [
        "storage"
    ],
    "action": {
        "default_popup": "src/popup/popup.html",
        "default_icon": {
            "16": "assets/icons/icon16.png",
            "32": "assets/icons/icon32.png",
            "48": "assets/icons/icon48.png",
            "128": "assets/icons/icon128.png"
        }
    },
    "options_page": "src/options/options.html",
    "icons": {
        "16": "assets/icons/icon16.png",
        "32": "assets/icons/icon32.png",
        "48": "assets/icons/icon48.png",
        "128": "assets/icons/icon128.png"
    }
}
